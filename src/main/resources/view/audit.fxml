<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?><?import javafx.scene.layout.*?><?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="controller.AuditController" spacing="16"
      styleClass="page-content">
    <padding>
        <Insets top="28" right="32" bottom="20" left="32"/>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="2">
            <Label text="Journal d'Audit" styleClass="page-title"/>
            <Label text="Auto-refresh 10s" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Actualiser" onAction="#handleRefresh" styleClass="btn-outline"/>
    </HBox>
    <HBox spacing="16" alignment="CENTER_LEFT">
        <!-- Counters — abbreviated French labels -->
        <HBox spacing="10">
            <HBox styleClass="counter-pill,counter-all" alignment="CENTER" spacing="4">
                <padding>
                    <Insets top="4" right="12" bottom="4" left="12"/>
                </padding>
                <Label text="Total" styleClass="counter-label"/>
                <Label fx:id="lblTotal" text="0" styleClass="counter-value"/>
            </HBox>
            <HBox styleClass="counter-pill,counter-ins" alignment="CENTER" spacing="4">
                <padding>
                    <Insets top="4" right="12" bottom="4" left="12"/>
                </padding>
                <Label text="INS" styleClass="counter-label"/>
                <Label fx:id="lblInserts" text="0" styleClass="counter-value"/>
            </HBox>
            <HBox styleClass="counter-pill,counter-upd" alignment="CENTER" spacing="4">
                <padding>
                    <Insets top="4" right="12" bottom="4" left="12"/>
                </padding>
                <Label text="MAJ" styleClass="counter-label"/>
                <Label fx:id="lblUpdates" text="0" styleClass="counter-value"/>
            </HBox>
            <HBox styleClass="counter-pill,counter-del" alignment="CENTER" spacing="4">
                <padding>
                    <Insets top="4" right="12" bottom="4" left="12"/>
                </padding>
                <Label text="SUP" styleClass="counter-label"/>
                <Label fx:id="lblDeletes" text="0" styleClass="counter-value"/>
            </HBox>
        </HBox>
        <Separator orientation="VERTICAL" prefHeight="28"/>
        <!-- Filter chips — full French names -->
        <HBox spacing="6">
            <Button text="Tout" onAction="#handleFilterAll" styleClass="chip-btn"/>
            <Button text="Insertion" onAction="#handleFilterInsert" styleClass="chip-btn"/>
            <Button text="Modification" onAction="#handleFilterUpdate" styleClass="chip-btn"/>
            <Button text="Suppression" onAction="#handleFilterDelete" styleClass="chip-btn"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="txtSearch" promptText="Rechercher..." prefWidth="240" styleClass="search-input"/>
    </HBox>
    <StackPane fx:id="tablePane" VBox.vgrow="ALWAYS">
        <VBox styleClass="glass-card" spacing="0">
            <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="modern-table">
                <columns>
                    <TableColumn text="Op." fx:id="colType"/>
                    <TableColumn text="Date" fx:id="colDate"/>
                    <TableColumn text="N" fx:id="colEtudiant"/>
                    <TableColumn text="Nom" fx:id="colNom"/>
                    <TableColumn text="Matiere" fx:id="colMatiere"/>
                    <TableColumn text="Anc." fx:id="colAncienne"/>
                    <TableColumn text="Nouv." fx:id="colNouvelle"/>
                    <TableColumn text="Utilisateur" fx:id="colUtilisateur"/>
                </columns>
                <placeholder>
                    <Label text="Aucune operation" styleClass="table-empty"/>
                </placeholder>
            </TableView>
            <HBox styleClass="table-footer" alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="10" right="16" bottom="10" left="16"/>
                </padding>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnPrev" text="&#8592;" onAction="#handlePrev" styleClass="btn-page"/>
                <Label fx:id="lblPage" styleClass="footer-page"/>
                <Button fx:id="btnNext" text="&#8594;" onAction="#handleNext" styleClass="btn-page"/>
            </HBox>
        </VBox>
    </StackPane>
</VBox>
