<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.DashboardController"
            fitToWidth="true" styleClass="page-scroll">
    <VBox spacing="24" styleClass="page-content">
        <padding>
            <Insets top="28" right="32" bottom="28" left="32"/>
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="2">
                <Label text="Dashboard" styleClass="page-title"/>
                <Label text="Vue d'ensemble des performances" styleClass="page-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Actualiser" onAction="#handleRefresh" styleClass="btn-outline"/>
        </HBox>

        <!-- Stat cards -->
        <HBox spacing="14">
            <VBox styleClass="stat-card,stat-blue" HBox.hgrow="ALWAYS">
                <Label text="Etudiants" styleClass="stat-label"/>
                <Label fx:id="statEtudiants" text="0" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-card,stat-purple" HBox.hgrow="ALWAYS">
                <Label text="Matieres" styleClass="stat-label"/>
                <Label fx:id="statMatieres" text="0" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-card,stat-green" HBox.hgrow="ALWAYS">
                <Label text="Notes" styleClass="stat-label"/>
                <Label fx:id="statNotes" text="0" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-card,stat-amber" HBox.hgrow="ALWAYS">
                <Label text="Moyenne" styleClass="stat-label"/>
                <Label fx:id="statMoyenne" text="--" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-card,stat-teal" HBox.hgrow="ALWAYS">
                <Label text="Reussite" styleClass="stat-label"/>
                <Label fx:id="statTaux" text="--" styleClass="stat-value"/>
            </VBox>
        </HBox>

        <!-- Row 1: BarChart + PieChart -->
        <HBox spacing="16">
            <StackPane fx:id="chartTopPane" HBox.hgrow="ALWAYS">
                <VBox styleClass="glass-card" spacing="8">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label text="Top Etudiants — Histogramme" styleClass="card-title"/>
                    <BarChart fx:id="chartTop" prefHeight="240" styleClass="custom-chart" animated="false">
                        <xAxis>
                            <CategoryAxis fx:id="topXAxis"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis fx:id="topYAxis"/>
                        </yAxis>
                    </BarChart>
                </VBox>
            </StackPane>
            <StackPane prefWidth="310" minWidth="290">
                <VBox styleClass="glass-card" spacing="8">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label text="Distribution des Notes" styleClass="card-title"/>
                    <PieChart fx:id="chartDistrib" prefHeight="240" styleClass="custom-chart"
                              animated="false" labelsVisible="false"/>
                </VBox>
            </StackPane>
        </HBox>

        <!-- Row 2: LineChart + AreaChart (NEW) -->
        <HBox spacing="16">
            <StackPane HBox.hgrow="ALWAYS">
                <VBox styleClass="glass-card" spacing="8">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label text="Courbe des Moyennes (Top)" styleClass="card-title"/>
                    <LineChart fx:id="chartLine" prefHeight="210" styleClass="custom-chart"
                               animated="false" createSymbols="true">
                        <xAxis>
                            <CategoryAxis fx:id="lineXAxis"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis fx:id="lineYAxis" lowerBound="0" upperBound="20"
                                        tickUnit="5" autoRanging="false"/>
                        </yAxis>
                    </LineChart>
                </VBox>
            </StackPane>
            <StackPane prefWidth="310" minWidth="290">
                <VBox styleClass="glass-card" spacing="8">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label text="Distribution — Courbe" styleClass="card-title"/>
                    <AreaChart fx:id="chartArea" prefHeight="210" styleClass="custom-chart"
                               animated="false" createSymbols="false">
                        <xAxis>
                            <CategoryAxis fx:id="areaXAxis"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis fx:id="areaYAxis"/>
                        </yAxis>
                    </AreaChart>
                </VBox>
            </StackPane>
        </HBox>

        <!-- Row 3: KPI Progress bars (NEW) -->
        <VBox styleClass="glass-card" spacing="14">
            <padding>
                <Insets top="18" right="22" bottom="18" left="22"/>
            </padding>
            <Label text="Indicateurs de Performance" styleClass="card-title"/>
            <VBox fx:id="kpiSection" spacing="12"/>
        </VBox>

        <!-- Row 4: Activite Recente (admin only) -->
        <VBox fx:id="activitySection" styleClass="glass-card" spacing="8">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>
            <Label text="Activite Recente" styleClass="card-title"/>
            <VBox fx:id="recentActivity" spacing="4"/>
        </VBox>

    </VBox>
</ScrollPane>
