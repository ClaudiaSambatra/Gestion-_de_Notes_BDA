<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.NoteController">

    <VBox spacing="12" AnchorPane.topAnchor="15" AnchorPane.leftAnchor="15"
          AnchorPane.rightAnchor="15" AnchorPane.bottomAnchor="15">

        <Label text="Gestion des Notes" styleClass="section-title"/>

        <!-- Info trigger -->
        <Label text="ℹ️  Toute modification déclenche automatiquement le recalcul de la moyenne et l'enregistrement dans l'Audit."
               styleClass="info-bar" wrapText="true"/>

        <!-- Formulaire -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="form-bar">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="N° Étudiant :"/>
            <TextField fx:id="txtNumEtudiant" promptText="ex: 101" prefWidth="100"/>
            <Label text="N° Matière :"/>
            <TextField fx:id="txtNumMat" promptText="ex: 1" prefWidth="100"/>
            <Label text="Note (0–20) :"/>
            <TextField fx:id="txtNote" promptText="ex: 15.5" prefWidth="100"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="➕ Ajouter"   onAction="#handleAdd"    styleClass="btn-add"/>
            <Button text="✏️ Modifier"  onAction="#handleUpdate"  styleClass="btn-update"/>
            <Button text="🗑️ Supprimer" onAction="#handleDelete"  styleClass="btn-delete"/>
            <Button text="🔄 Effacer"   onAction="#handleClear"   styleClass="btn-clear"/>
        </HBox>

        <!-- Tableau des notes -->
        <TableView fx:id="tableNote" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="N° Étudiant" fx:id="colEtudiant" prefWidth="150"/>
                <TableColumn text="N° Matière"  fx:id="colMat"      prefWidth="150"/>
                <TableColumn text="Note"         fx:id="colNote"     prefWidth="150"/>
            </columns>
            <placeholder><Label text="Aucune note enregistrée"/></placeholder>
        </TableView>

        <Label fx:id="lblMessage" styleClass="msg-label"/>
    </VBox>
</AnchorPane>
