<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.MainController"
      spacing="0" styleClass="root-container">

    <!-- Barre de titre -->
    <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="15">
        <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
        <Label text="🎓 Gestion des Notes" styleClass="header-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblUtilisateur" styleClass="header-user"/>
    </HBox>

    <!-- Onglets -->
    <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS" styleClass="main-tabs"/>
</VBox>
