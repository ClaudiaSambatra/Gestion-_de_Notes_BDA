<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.AuditController">

    <VBox spacing="12" AnchorPane.topAnchor="15" AnchorPane.leftAnchor="15"
          AnchorPane.rightAnchor="15" AnchorPane.bottomAnchor="15">

        <Label text="Journal d'Audit des Notes" styleClass="section-title"/>

        <!-- Barre de filtres -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="form-bar">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="Filtrer par type :"/>
            <TextField fx:id="txtFiltreType" promptText="INSERT / UPDATE / DELETE" prefWidth="180"/>
            <Button text="🔍 Filtrer"       onAction="#handleFiltre"      styleClass="btn-update"/>
            <Separator orientation="VERTICAL"/>
            <Button text="Tout"             onAction="#handleShowAll"     styleClass="btn-clear"/>
            <Button text="➕ Insertions"    onAction="#handleShowInsert"  styleClass="btn-add"/>
            <Button text="✏️ Modifications" onAction="#handleShowUpdate"  styleClass="btn-update"/>
            <Button text="🗑️ Suppressions"  onAction="#handleShowDelete"  styleClass="btn-delete"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔄 Actualiser"    onAction="#handleRefresh"     styleClass="btn-clear"/>
        </HBox>

        <!-- Tableau Audit -->
        <TableView fx:id="tableAudit" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="Opération"      fx:id="colType"        prefWidth="100"/>
                <TableColumn text="Date/Heure"     fx:id="colDate"        prefWidth="160"/>
                <TableColumn text="N° Étudiant"    fx:id="colEtudiant"    prefWidth="100"/>
                <TableColumn text="Nom"            fx:id="colNom"         prefWidth="140"/>
                <TableColumn text="Matière"        fx:id="colMatiere"     prefWidth="140"/>
                <TableColumn text="Anc. Note"      fx:id="colAncienne"    prefWidth="90"/>
                <TableColumn text="Nouv. Note"     fx:id="colNouvelle"    prefWidth="90"/>
                <TableColumn text="Utilisateur"    fx:id="colUtilisateur" prefWidth="110"/>
            </columns>
            <placeholder><Label text="Aucune opération enregistrée dans l'audit"/></placeholder>
        </TableView>

        <!-- Compteurs en bas -->
        <HBox spacing="0" styleClass="compteur-bar">
            <padding><Insets top="10" right="15" bottom="10" left="15"/></padding>
            <Label text="📊  Récapitulatif : " styleClass="compteur-titre"/>
            <Label fx:id="lblInserts"    styleClass="compteur-insert"  HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUpdates"    styleClass="compteur-update"  HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDeletes"    styleClass="compteur-delete"  HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblTotal"      styleClass="compteur-total"/>
        </HBox>

    </VBox>
</AnchorPane>
