<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.MatiereController">

    <VBox spacing="12" AnchorPane.topAnchor="15" AnchorPane.leftAnchor="15"
          AnchorPane.rightAnchor="15" AnchorPane.bottomAnchor="15">

        <Label text="Gestion des Matières" styleClass="section-title"/>

        <!-- Formulaire -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="form-bar">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="N° Matière :"/>
            <TextField fx:id="txtNum" promptText="ex: 1" prefWidth="90"/>
            <Label text="Désignation :"/>
            <TextField fx:id="txtDesign" promptText="ex: Mathématiques" prefWidth="200"/>
            <Label text="Coefficient :"/>
            <TextField fx:id="txtCoef" promptText="ex: 3" prefWidth="80"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="➕ Ajouter"   onAction="#handleAdd"    styleClass="btn-add"/>
            <Button text="✏️ Modifier"  onAction="#handleUpdate"  styleClass="btn-update"/>
            <Button text="🗑️ Supprimer" onAction="#handleDelete"  styleClass="btn-delete"/>
            <Button text="🔄 Effacer"   onAction="#handleClear"   styleClass="btn-clear"/>
        </HBox>

        <!-- Tableau -->
        <TableView fx:id="tableMatiere" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="N° Matière"   fx:id="colNum"    prefWidth="120"/>
                <TableColumn text="Désignation"  fx:id="colDesign" prefWidth="350"/>
                <TableColumn text="Coefficient"  fx:id="colCoef"   prefWidth="120"/>
            </columns>
            <placeholder><Label text="Aucune matière enregistrée"/></placeholder>
        </TableView>

        <Label fx:id="lblMessage" styleClass="msg-label"/>
    </VBox>
</AnchorPane>
