<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.EtudiantController">

    <VBox spacing="12" AnchorPane.topAnchor="15" AnchorPane.leftAnchor="15"
          AnchorPane.rightAnchor="15" AnchorPane.bottomAnchor="15">

        <Label text="Gestion des Étudiants" styleClass="section-title"/>

        <!-- Formulaire -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="form-bar">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="N° Étudiant :"/>
            <TextField fx:id="txtNum" promptText="ex: 101" prefWidth="100"/>
            <Label text="Nom :"/>
            <TextField fx:id="txtNom" promptText="ex: Jean Dupont" prefWidth="200"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="➕ Ajouter"    onAction="#handleAdd"    styleClass="btn-add"/>
            <Button text="✏️ Modifier"   onAction="#handleUpdate"  styleClass="btn-update"/>
            <Button text="🗑️ Supprimer"  onAction="#handleDelete"  styleClass="btn-delete"/>
            <Button text="🔄 Actualiser" onAction="#handleRefresh" styleClass="btn-clear"/>
        </HBox>

        <!-- Tableau -->
        <TableView fx:id="tableEtudiant" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="N° Étudiant" fx:id="colNum"     prefWidth="120"/>
                <TableColumn text="Nom"          fx:id="colNom"     prefWidth="300"/>
                <TableColumn text="Moyenne"      fx:id="colMoyenne" prefWidth="150"/>
            </columns>
            <placeholder><Label text="Aucun étudiant enregistré"/></placeholder>
        </TableView>

        <Label fx:id="lblMessage" styleClass="msg-label"/>
    </VBox>
</AnchorPane>
