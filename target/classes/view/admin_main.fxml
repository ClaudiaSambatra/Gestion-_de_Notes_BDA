<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootStack" xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.AdminMainController" styleClass="root-stack">
    <HBox styleClass="main-layout">
        <VBox styleClass="sidebar" prefWidth="220" minWidth="220" maxWidth="220" spacing="4">
            <padding>
                <Insets top="20" right="12" bottom="16" left="12"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets bottom="20" left="4"/>
                </padding>
                <Label text="GN" styleClass="brand-icon"/>
                <VBox>
                    <Label text="GestNotes" styleClass="brand-title"/>
                    <Label text="Administration" styleClass="brand-sub"/>
                </VBox>
            </HBox>
            <Label text="NAVIGATION" styleClass="nav-section-label"/>
            <Button fx:id="btnDashboard" text="     Dashboard" styleClass="nav-btn" maxWidth="Infinity"/>
            <Button fx:id="btnAudit"     text="     Audit"     styleClass="nav-btn" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>
            <Button fx:id="btnTheme" text="&#9790; Sombre" styleClass="nav-btn,nav-btn-secondary" maxWidth="Infinity"/>
            <HBox styleClass="user-pill" alignment="CENTER_LEFT" spacing="8">
                <padding>
                    <Insets top="8" right="8" bottom="8" left="8"/>
                </padding>
                <Label text="A" styleClass="user-avatar"/>
                <VBox>
                    <Label fx:id="lblUser" styleClass="user-name"/>
                    <Label text="Administrateur" styleClass="user-role"/>
                </VBox>
            </HBox>
        </VBox>
        <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS" styleClass="content-area"/>
    </HBox>
    <VBox fx:id="toastContainer" pickOnBounds="false" spacing="8" maxWidth="380" StackPane.alignment="TOP_RIGHT">
        <padding>
            <Insets top="16" right="16"/>
        </padding>
    </VBox>
</StackPane>
